    #replace text {{в– |вҖ–|в–ү|в–Ҡ|в–Ӣ|в–Ң|в–Қ|в–Һ|в–Ҹ}}                      {&1 };
    #replace text {{вҖ»|вҳҶ|ОЁ|вҳ…|в–Ў|в—Һ|вҠҷ|в—Ҹ|В·|Г—|вҲ¶|вҲ·|вүҲ|вҲҡ|вҢ’|О©}}  {&1 };
    #replace text {{в–ј|Р–|Оҫ|С„|вҲ©|вҠҘ|вҷҖ|вҲһ|в—Ү|в—Ҷ|оӢӘ}} {&1 };
    #replace text {{в‘ |в‘Ў|в‘ў|в‘Ј|в‘Ө|в‘Ҙ|в‘Ұ|в‘§|в‘Ё|вҖң|вҖқ}}                {&1 };
    #replace text {{в”Ӯ|в”ғ|в•‘|в”Ҷ|в”Ү|в”Ҡ|в”Ӣ|в”Ө|в”Ё|в”«|в•Ј|в•ў|в•Ў}}    {&1 };
    #replace text {{в”җ|в”“|в”’|в•®|в•—|в”ҳ|в”ӣ|в”ҡ|в•Ҝ|в•қ}}             {&1 };
    #replace text {{в•І|в•ұ|вүӨ|вүҘ|вү®|вүҜ|вҶҷ|вҶҳ|вҶ—|вҶ–|вҶҗ|вҶ‘|вҶ’|вҶ“|вҲЁ|вҲ§}} {&1 };

    #format result {%s} {$text};
};

#class beautify close;

beautify;
